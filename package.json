  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "nuxt dev --port 9001",
    "build": "nuxt generate",
    "dev:electron": "cross-env ELECTRON=true nuxt dev --port 9001",
    "build:electron": "cross-env ELECTRON=true nuxt generate",
    "package:electron": "electron-builder --config=electron_builder.js",
    "preview": "cross-env PORT=9001 nuxt preview",
    "coverage": "vitest run --coverage",
    "e2e": "cypress open",
    "lint": "stylelint \"**/*.{vue,scss}\" && prettier . --check && eslint --ext ts,js,vue,json . && ELECTRON=true nuxi typecheck",
    "lint:fix": "stylelint --fix \"**/*.{vue,scss}\" && prettier . --write && eslint --fix --ext ts,js,vue,json .",
    "test": "vitest",
    "postinstall": "nuxt prepare"
  },
